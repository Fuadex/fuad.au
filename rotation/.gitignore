# Rotation app — ignore rules (nested; paths relative to rotation/)

# large local datasets — never commit
# (.gitignore has NO inline comments — patterns must stand alone on their own line)
*.parquet
*.zip
# compressed lyrics/data dumps + any DB unpacked from them (e.g. LRCLIB) — PRIVATE, local-only
*.gz
*.sqlite
*.sqlite3
*.db
archive.zip
archive_genius.zip   # Genius lyrics dump (~3 GB) — local-only
# personal Spotify exports — PRIVATE (contain IP addresses + liked songs), never commit
my_spotify_data*.zip
Spotify Extended Streaming History/
Spotify Account Data/
spotify-sync.log
gigs-local.json
# scratch logs from background enrichment runs
*-run.log

# local notes
CSV-OVERRIDES.md
IDEAS.md

# generated by build-data.js / sync-live.js — built in CI, deployed as a Pages
# artifact, never committed (see ROADMAP A2). world-map.js is static and STAYS committed.
music-core.js
music-rest.js
day-series.js
pulse.js
genius-mood-lazy.js
genius-about-lazy.js
genius-themes-lazy.js
live-data.js
search-index.js
media-index.js
track-audio.js
track-previews.js
shelves-unplayed.js
artist-flow.js
artist-detail.js
calendar.js
calendar-detail.js
geo-detail.js
tm-tour-lazy.js
album-about-lazy.js
album-alias.js
artist-days.js

# llm-about shards + theme index — CI artifacts from shard-about.js (which STAYS committed).
# llm-about.js itself remains the committed source of truth; only the split output is ignored.
about/
