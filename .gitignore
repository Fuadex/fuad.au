# fuad.au hub — root ignores. Each app owns a nested .gitignore
# (rotation/.gitignore, culture/.gitignore).

# deploy staging, assembled by stage-site.js on every build
_site/

# local Babel install for stage-site.js precompile checks (CI installs its own)
node_modules/
package.json
package-lock.json

# secrets — never commit (hub-level .env + any nested app .env)
.env
*.env
**/.env

# local-only working notes (audits, drafts) — *.local.md never commits
*.local.md

# dated snapshots / moved originals — kept for reference but not tracked
notes/

# OS / editor cruft
.DS_Store
Thumbs.db
